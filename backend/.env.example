PORT=4000
FRONTEND_URL=http://localhost:3000

# AWS credentials (use IAM role on EC2, not hardcoded keys)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_key_here
AWS_SECRET_ACCESS_KEY=your_secret_here

# DynamoDB table names
DYNAMO_SUBSCRIBERS_TABLE=portfolio-subscribers
DYNAMO_POSTS_TABLE=portfolio-posts

# SES — must be a verified sender address in your AWS account
SES_FROM_EMAIL=newsletter@yourdomain.com
SES_FROM_NAME=Your Name
